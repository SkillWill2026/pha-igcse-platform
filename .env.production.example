# ─────────────────────────────────────────────────────────────────────────────
# PHA IGCSE Platform — production environment variables
#
# Copy these into Vercel: Project Settings → Environment Variables
# Set each one for the "Production" (and optionally "Preview") environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: supabase.com/dashboard → your project → Project Settings → API

# The public URL for your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# The service-role secret key — KEEP THIS SECRET, never share it
# Grants full database access; used only on the server
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Found at: console.anthropic.com → API Keys → Create Key

ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
