# ─────────────────────────────────────────────────────────────
# PHA IGCSE Platform — required environment variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (found in: Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key (server-side only — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic API key for AI question extraction / answer generation
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
