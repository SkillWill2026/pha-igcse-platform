generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model answers {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id      String?   @db.Uuid
  content_text     String?
  status           String?   @default("draft")
  created_by       String?   @db.Uuid
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  serial_number    String?
  content          String?
  step_by_step     String?
  mark_scheme      String?
  confidence_score Float?
  ai_generated     Boolean?  @default(false)
}

model databank_chunks {
  id          String                 @id @db.Uuid
  document_id String                 @db.Uuid
  content     String
  embedding   Unsupported("vector")?
  page_number Int?
  chunk_index Int
  token_count Int?
  created_at  DateTime?              @db.Timestamptz(6)
}

model databank_documents {
  id                String    @id @db.Uuid
  title             String
  doc_type          String
  topic_id          String?   @db.Uuid
  file_path         String
  file_name         String
  file_size         Int?
  page_count        Int?
  chunk_count       Int?
  processing_status String
  processing_error  String?
  created_at        DateTime? @db.Timestamptz(6)
  updated_at        DateTime? @db.Timestamptz(6)
  subject_id        String?   @db.Uuid
  uploaded_by       String?   @db.Uuid
}

model error_logs {
  id         String    @id @db.Uuid
  message    String?
  stack      String?
  url        String?
  user_agent String?
  created_at DateTime? @db.Timestamptz(6)
}

model exam_boards {
  id         String   @id @db.Uuid
  name       String
  created_at DateTime @db.Timestamptz(6)
}

model ppt_decks {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String?
  subtopic_id   String?   @db.Uuid
  status        String?   @default("draft")
  slides        Json?
  created_by    String?   @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  filename      String?
  file_path     String?
  file_size     Int?
  subject_id    String?   @db.Uuid
  topic_id      String?   @db.Uuid
  exam_board_id String?   @db.Uuid
  tutor_notes   String?
}

model production_targets {
  id           String    @id @db.Uuid
  total_target Int
  start_date   DateTime  @db.Date
  end_date     DateTime  @db.Date
  created_at   DateTime? @db.Timestamptz(6)
  updated_at   DateTime? @db.Timestamptz(6)
  subject_id   String?   @db.Uuid
}

model production_topic_targets {
  id         String    @id @db.Uuid
  topic_id   String    @db.Uuid
  target     Int
  created_at DateTime? @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
  subject_id String?   @db.Uuid
}

model profiles {
  id         String    @id @db.Uuid
  email      String?
  role       String?   @default("tutor")
  full_name  String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model question_images {
  id           String    @id @db.Uuid
  question_id  String    @db.Uuid
  storage_path String
  public_url   String?
  image_type   String
  caption      String?
  sort_order   Int
  uploaded_by  String?   @db.Uuid
  created_at   DateTime? @db.Timestamptz(6)
  display_url  String?
}

model questions {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content_text        String?
  difficulty          String?
  marks               Int?
  topic_id            String?   @db.Uuid
  subtopic_id         String?   @db.Uuid
  sub_subtopic_id     String?   @db.Uuid
  exam_board_id       String?   @db.Uuid
  status              String?   @default("draft")
  batch_id            String?   @db.Uuid
  created_by          String?   @db.Uuid
  has_image           Boolean?  @default(false)
  question_number     Int?
  source_page         Int?
  year                Int?
  paper               String?
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  serial_number       String?
  image_url           String?
  question_type       String?
  source_question_id  String?   @db.Uuid
  ai_extracted        Boolean?  @default(false)
  is_example          Boolean?  @default(false)
  batch_position      Int?
  parent_question_ref String?
  part_label          String?
  calculator          Boolean?  @default(false)
}

model sub_subtopics {
  id          String    @id @db.Uuid
  subtopic_id String    @db.Uuid
  ext_num     Int
  core_num    Int?
  outcome     String
  tier        String
  notes       String?
  sort_order  Int
  created_at  DateTime? @db.Timestamptz(6)
}

model subjects {
  id         String    @id @db.Uuid
  name       String
  code       String
  color      String
  active     Boolean
  sort_order Int
  created_at DateTime? @db.Timestamptz(6)
}

model subtopics {
  id                String    @id @db.Uuid
  topic_id          String    @db.Uuid
  ref               String
  title             String
  due_date          DateTime? @db.Date
  sprint_week       String?
  qs_total          Int
  mcq_count         Int
  short_ans_count   Int
  structured_count  Int
  extended_count    Int
  status            String
  sort_order        Int
  created_at        DateTime? @db.Timestamptz(6)
  ppt_required      Boolean
  examples_required Int
  tier              String
}

model topics {
  id              String    @id @db.Uuid
  ref             String
  name            String
  subtopic_count  Int
  total_questions Int
  ppt_decks       Int
  completion_date DateTime? @db.Date
  hours_est       Int?
  sort_order      Int
  created_at      DateTime? @db.Timestamptz(6)
  subject_id      String?   @db.Uuid
}

model tutor_topic_assignments {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  topic_id     String    @db.Uuid
  subject_id   String    @db.Uuid
  daily_target Int?
  created_at   DateTime? @db.Timestamptz(6)
}

model upload_batches {
  id                        String    @id @db.Uuid
  created_by                String?   @db.Uuid
  total_files               Int
  completed_files           Int
  failed_files              Int
  total_questions_extracted Int
  topic_id                  String?   @db.Uuid
  subtopic_id               String?   @db.Uuid
  sub_subtopic_id           String?   @db.Uuid
  status                    String
  created_at                DateTime? @db.Timestamptz(6)
  completed_at              DateTime? @db.Timestamptz(6)
  source_pdf_path           String?
  source_file_name          String?
  storage_path              String?
  total_questions           Int?
  questions_extracted       Int?
  error_message             String?
}

